# OpenHearth environment overrides.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and edit.
# Docker Compose loads `.env` automatically; values here fill the `${VAR}`
# placeholders in docker-compose.yml. `.env` is gitignored — never commit it.

# --- Run as your host user -------------------------------------------------
# The container writes to ./config and ./cache. By default it runs as UID/GID
# 1000 (the image's built-in `node` user); if your host user differs, files end
# up owned by the wrong user (or root), which is inconvenient to edit.
#
# Set these to YOUR ids so new files are owned by you. Find them with:
#   id -u   # -> PUID
#   id -g   # -> PGID
PUID=1000
PGID=1000

# --- Media library SMB/CIFS share ------------------------------------------
# Credentials for the network share mounted at /media (see the `media` volume in
# docker-compose.yml). On Windows, do NOT bind-mount a drive letter like Z:\ —
# mapped drives only exist in your login session and are invisible to Docker's
# WSL2 VM. Mount the underlying share instead. Use a domain login as DOMAIN\user
# or just the username for a local account. Leave blank if the share allows
# guest access (and add `guest` to the `o:` options in docker-compose.yml).
# Full walkthrough: docs/deployment/host-parity.md § "mounting /media from a
# network share (SMB/CIFS)".
SMB_USER=
SMB_PASS=

# --- Metadata provider (optional) ------------------------------------------
# TMDB API key for artwork/metadata. The app is fully usable without it (no
# outbound calls are made when unset). You can also set this in
# config/openhearth.yaml instead.
TMDB_API_KEY=
